# 服务端监听端口。留空时默认使用 3000。
PORT=

# 模型服务 API Key。填写你的模型供应商密钥，不要提交到公开仓库。
LLM_API_KEY=

# OpenAI 兼容接口地址。例如：https://api.example.com/v1
LLM_BASE_URL=

# 默认模型名称，必须是供应商支持的实际模型名。
DEFAULT_MODEL=

# 前端允许选择的模型列表，多个模型用英文逗号分隔。例如：model-a,model-b
ALLOWED_MODELS=

# 默认温度，控制回复随机性。通常填 0.2 到 1.0，留空默认 0.8。
DEFAULT_TEMPERATURE=

# 单次回复最大 token 数。按模型上下文限制填写，留空默认 4096。
DEFAULT_MAX_TOKENS=

# JWT 签名密钥。必须填写足够随机的长字符串，建议 32 位以上。
JWT_SECRET=

# 初始管理员用户名。留空则不会自动创建管理员。
ADMIN_USERNAME=

# 初始管理员密码。仅在 ADMIN_USERNAME 同时填写时生效。
ADMIN_PASSWORD=

# 管理员重置用户密码和用量的独立密钥。需要使用重置功能时填写。
ADMIN_RESET_KEY=

# CORS 允许来源，多个地址用英文逗号分隔。留空表示允许任意来源。
ALLOWED_ORIGINS=

# Access Token 有效期。例如：15m、1h。留空默认 15m。
ACCESS_TOKEN_EXPIRE=

# Refresh Token 有效期。例如：7d、30d。留空默认 7d。
REFRESH_TOKEN_EXPIRE=

# 普通用户每日 token 上限。管理员不受限制，留空默认 30000。
DAILY_TOKEN_LIMIT=

# 同一 IP 最多注册账号数。留空默认 3。
MAX_REGISTER_PER_IP=

# 自定义角色配置文件路径。留空时读取 server/config/character.json。
CHARACTER_CONFIG_PATH=
